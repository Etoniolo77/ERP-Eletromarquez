# Substitua por sua connection string do Supabase na aba "Database Settings -> Connection string -> URI"
# Lembre de trocar as "[]" pela sua senha e marcar porta 6543 se usar o Supabase.
SUPABASE_DB_URL="postgresql://postgres.[nome_do_projeto]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"
